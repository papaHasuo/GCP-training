{
  "hosting": {
    "public": "internal-web/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "codebase": "default",
      "source": "functions",
      "runtime": "python314",
      "ignore": [
        "venv",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "environmentVariables": {
        "ALLOWED_ORIGIN": "https://us-central1-gcp-learning-497122.cloudfunctions.net"
      }
    }
  ]
}
